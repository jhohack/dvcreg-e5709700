name: dvcreg
region: sgp
static_sites:
  - name: web
    github:
      repo: YOUR_GITHUB_USERNAME/YOUR_REPOSITORY
      branch: main
      deploy_on_push: true
    build_command: npm ci && npm run build
    output_dir: dist
    catchall_document: index.html
    routes:
      - path: /
    envs:
      - key: VITE_API_BASE_URL
        scope: BUILD_TIME
        value: ""
