name: dvcreg
region: sgp
services:
  - name: web
    dockerfile_path: Dockerfile
    http_port: 8080
    instance_count: 1
    instance_size_slug: apps-s-1vcpu-1gb
    github:
      repo: YOUR_GITHUB_USERNAME/YOUR_REPOSITORY
      branch: main
      deploy_on_push: true
    envs:
      - key: SMTP_HOST
        scope: RUN_TIME
        value: your_smtp_host
      - key: SMTP_PORT
        scope: RUN_TIME
        value: "587"
      - key: SMTP_USERNAME
        scope: RUN_TIME
        value: dvcregistrar@dvci-edu.com
      - key: SMTP_PASSWORD
        scope: RUN_TIME
        value: your_smtp_password
        type: SECRET
      - key: SMTP_SECURE
        scope: RUN_TIME
        value: tls
      - key: MAIL_FROM_ADDRESS
        scope: RUN_TIME
        value: dvcregistrar@dvci-edu.com
      - key: MAIL_FROM_NAME
        scope: RUN_TIME
        value: DVC Registration
      - key: MAIL_CODE_TTL_MINUTES
        scope: RUN_TIME
        value: "10"
      - key: SMTP_TIMEOUT_SECONDS
        scope: RUN_TIME
        value: "20"
      - key: VITE_SUPABASE_URL
        scope: RUN_TIME
        value: https://your-project-ref.supabase.co
      - key: SUPABASE_SERVICE_ROLE_KEY
        scope: RUN_TIME
        value: your_supabase_service_role_key
        type: SECRET
      - key: ALLOWED_ORIGINS
        scope: RUN_TIME
        value: https://your-app-url.ondigitalocean.app,https://your-custom-domain.com
      - key: REMBG_COMMAND
        scope: RUN_TIME
        value: rembg
      - key: REMBG_MODEL
        scope: RUN_TIME
        value: isnet-general-use
